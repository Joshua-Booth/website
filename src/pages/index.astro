---
import { AstroSeo } from "@astrolib/seo";
import { Container, Flex, Heading, Link } from "@radix-ui/themes";

import BentoGrid from "@/components/home/bento-grid.astro";
import ContactSection from "@/components/home/contact-section.astro";
import MovingCards from "@/components/home/moving-cards.astro";
import BlurIn from "@/components/ui/blur-in";
import Spotlight from "@/components/ui/spotlight.astro";
import { ThemeSwitcher } from "@/components/ui/theme-switcher";

import BaseLayout from "../layouts/base-layout.astro";

const pageTitle = "Joshua Booth | UI Engineer";
---

<AstroSeo
  title={pageTitle}
  description="UI Engineer building thoughtful web experiences and design systems. Based in Auckland, New Zealand."
  canonical="https://joshuabooth.nz/"
  openGraph={{
    url: "https://joshuabooth.nz/",
    title: pageTitle,
    description:
      "UI Engineer building thoughtful web experiences and design systems. Based in Auckland, New Zealand.",
    images: [
      {
        url: "https://joshuabooth.nz/images/og-image.jpg",
        width: 1200,
        height: 630,
        alt: "Joshua Booth - UI Engineer",
      },
    ],
    site_name: "Joshua Booth",
  }}
  twitter={{
    handle: "@joshuaboothnz",
    site: "@joshuaboothnz",
    cardType: "summary_large_image",
  }}
/>

<BaseLayout>
  <header slot="header" class="absolute z-20 w-full">
    <Container size="4" px="8" py="4">
      <Flex direction="row" align="center" justify="between">
        <Link href="/" color="gray">
          <Heading as="h1">Joshua Booth</Heading>
        </Link>
        <Flex gap="6" align="center">
          <Link
            href="#contact"
            size="2"
            color="gray"
            className="hidden [@media(min-width:380px)]:block"
          >
            Contact
          </Link>
          <ThemeSwitcher client:idle />
        </Flex>
      </Flex>
    </Container>
  </header>

  <div
    class="relative flex h-128 w-full items-center overflow-hidden rounded-md bg-grid-black/2 antialiased md:h-160 md:justify-center dark:bg-grid-white/2"
  >
    <Spotlight
      class="-top-40 left-0 hidden md:-top-20 md:left-60 2xl:left-[20%] dark:block"
      fill="var(--blue-7)"
    />
    <div class="relative z-10 mx-auto w-full max-w-7xl p-4 pt-20 md:pt-0">
      <BlurIn
        word="UI Engineer"
        client:load
        className="bg-linear-to-b from-(--gray-a12) to-(--gray-a7) bg-clip-text text-transparent drop-shadow-2xl md:h-21"
      />
      <p
        class="mx-auto mt-4 max-w-lg text-center text-base font-normal text-(--gray-11)"
      >
        Building web experiences that look beautiful and <span
          class="text-(--blue-11)">work even better</span
        >.
      </p>
    </div>
  </div>

  <BentoGrid />

  <MovingCards />

  <ContactSection />
</BaseLayout>
