---
import { links } from "@/config";
import { SiGithub, SiInstagram, SiX } from "@icons-pack/react-simple-icons";
import {
  Card,
  Container,
  Flex,
  Heading,
  Link,
  Separator,
  Text,
} from "@radix-ui/themes";
import { MailIcon } from "lucide-react";

import ContactForm from "@/components/shared/contact-form.astro";
---

<Container size="3" p="9" style={{ backgroundColor: "var(--gray-2)" }}>
  <Flex
    direction={{ initial: "column", sm: "row" }}
    gap="8"
    align="start"
    pt="8"
  >
    <Flex direction="column" gap="8" width="100%" style={{ flex: "1 1 50%" }}>
      <Flex direction="column" gap="4" id="contact">
        <Heading size="8" weight="bold">Let's talk</Heading>
        <Text size="2" color="gray">
          Have a project in mind? Tell me what you're building.
        </Text>
      </Flex>

      <Separator size="3" />

      <Flex gap="6">
        <Link href={links.instagram} aria-label="Instagram">
          <SiInstagram size={16} />
        </Link>
        <Link href={links.x} aria-label="X (Twitter)">
          <SiX size={16} />
        </Link>
        <Link href={links.github} aria-label="GitHub">
          <SiGithub size={16} />
        </Link>
        <Link href={links.email} aria-label="Email">
          <MailIcon size={16} />
        </Link>
      </Flex>
    </Flex>

    <Flex direction="column" gap="4" width="100%" style={{ flex: "1 1 50%" }}>
      <Card size="3">
        <ContactForm />
      </Card>
    </Flex>
  </Flex>
</Container>
